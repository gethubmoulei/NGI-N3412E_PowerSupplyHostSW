  <property name="styleSheet">
   <string notr="true">QWidget {
                background-color: #f7f7f7;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
                color: #333;
            }
            QPushButton {
                background-color: #007aff;
                border:  2px solid #007aff;
                color: white;
                padding: 0px 0px;
                text-align: center;
                text-decoration: none;
                margin: 0px 3px;
                border-radius: 5px;
                font-size: inherit;
            }
            QPushButton:hover {
                background-color: #005bb5;
            }
			QPushButton:disabled {
                background-color: #cccccc;
				border:  2px solid #cccccc;
                color: #666666;
            }
			QPushButton:pressed {
        		border-style: inset;
            }
			QLCDNumber {
                background-color:rgb(184, 223, 142);
                color: black;
				border: none;
                padding: 0px 0px;
                text-align: center;
                text-decoration: none;
                margin: 0px 1px;
                border-radius: 0px;
                font-size: inherit;
            }
			QLCDNumber:disabled {
                background-color: #cccccc;
                color: #666666;
            }
            QLabel {
                font-size: inherit;
                color: #333;
            }
			QLabel:disabled {
                background-color: #cccccc;
                color: #666666;
            }

            QGroupBox {
                font-size: inherit;
                font-weight: bold;
                color: #555;
                border: 1px solid #ddd;
                border-radius: 10px;
                margin-top: 10px;
                padding: 10px;
                background-color: #fff;
            }
            QGroupBox::title {
                subcontrol-origin: margin;
                subcontrol-position: top left;
                padding: 0 3px;
                background-color: #fff;
                border-radius: 5px;
            }
			QGroupBox:disabled {
                color: gray;
                background-color: lightgray;
            }
</string>
